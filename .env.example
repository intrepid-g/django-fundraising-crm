# Django Fundraising CRM - Environment Variables
# Copy this file to .env and customize for your environment

# =============================================================================
# Django Core Settings
# =============================================================================

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=True

# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL (recommended for production)
DATABASE_URL=postgres://postgres:postgres@db:5432/django_crm

# SQLite (for local development only)
# DATABASE_URL=sqlite:///db.sqlite3

# =============================================================================
# Cache & Session Configuration
# =============================================================================

# Redis (recommended)
REDIS_URL=redis://redis:6379/0

# Local memory cache (development only)
# CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache

# =============================================================================
# Email Configuration
# =============================================================================

# SMTP Settings (for sending emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Console backend (for development - prints to console)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =============================================================================
# Security Settings (Production)
# =============================================================================

# Enable HTTPS redirect
# SECURE_SSL_REDIRECT=True

# HTTP Strict Transport Security
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Cookie security
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# =============================================================================
# Logging & Monitoring
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# =============================================================================
# API & External Services
# =============================================================================

# Django Ninja API settings
NINJA_API_URL=/api/

# Rate limiting (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
ENABLE_WEBHOOKS=False
ENABLE_BULK_IMPORT=True
ENABLE_REPORT_EXPORT=True

# =============================================================================
# Development Settings
# =============================================================================

# Django Debug Toolbar (development only)
ENABLE_DEBUG_TOOLBAR=True

# Auto-reload on code changes
PYTHONUNBUFFERED=1

# =============================================================================
# Production Checklist
# =============================================================================
# Before deploying to production, ensure:
# [ ] DEBUG is set to False
# [ ] SECRET_KEY is changed to a secure random value
# [ ] ALLOWED_HOSTS includes your domain
# [ ] DATABASE_URL points to production database
# [ ] Email settings are configured
# [ ] SSL/HTTPS settings are enabled
# [ ] Static files are collected (python manage.py collectstatic)
# [ ] Migrations are applied (python manage.py migrate)
